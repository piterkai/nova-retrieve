# ====== LLM (OpenAI-compatible Chinese provider e.g. DeepSeek / Qwen / Zhipu) ======
LLM_BASE_URL=https://api.deepseek.com/v1
LLM_API_KEY=sk-xxxxx
LLM_MODEL=deepseek-chat
LLM_ROUTER_MODEL=deepseek-chat
LLM_TEMPERATURE=0.1
LLM_TIMEOUT=60

# ====== Embedding (BGE-M3 via sentence-transformers) ======
# 优先使用本地目录；为空则按 EMBEDDING_MODEL 从 HuggingFace 下载
EMBEDDING_LOCAL_PATH=/absolute/path/to/bge-m3
EMBEDDING_MODEL=BAAI/bge-m3
EMBEDDING_DEVICE=cpu          # 或 cuda / mps
EMBEDDING_DIM=1024

# ====== Qdrant ======
QDRANT_URL=http://localhost:6333
QDRANT_API_KEY=
QDRANT_COLLECTION=nova_retrieve_docs

# ====== Retrieval ======
RETRIEVAL_TOP_K=6
RETRIEVAL_SCORE_THRESHOLD=0.3
RETRIEVAL_MAX_RETRIES=2

# ====== Tavily Web Search (fallback) ======
TAVILY_API_KEY=
TAVILY_MAX_RESULTS=5

# ====== Server ======
APP_HOST=0.0.0.0
APP_PORT=8000
APP_LOG_LEVEL=INFO
APP_CORS_ORIGINS=*
